# === Database ===
DATABASE_URL=postgresql://polymarket:polymarket_dev_password@localhost:5432/polymarket
REDIS_URL=redis://localhost:6379/0
DB_POOL_MIN=2
DB_POOL_MAX=10

# === Falcon API (polymarketanalytics.com) ===
FALCON_API_KEY=
FALCON_API_URL=https://narrative.agent.heisenberg.so/api/v2/semantic/retrieve/parameterized
FALCON_REFRESH_INTERVAL_S=3600
FALCON_CACHE_TTL_S=172800

# === Leader Registry ===
INITIAL_LEADER_COUNT=200
MAX_LEADER_COUNT=2000
MIN_FALCON_SCORE=0.0

# === Trade Observer ===
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
TOP_MARKETS_COUNT=50
WEBSOCKET_PING_INTERVAL_S=30
WEBSOCKET_PONG_TIMEOUT_S=10

# === Graph Engine ===
FOLLOWER_WINDOW_S=300
MIN_CO_OCCURRENCES=5
MIN_SAME_DIRECTION_RATE=0.7
HAWKES_LOOKBACK_DAYS=30

# === Profiler ===
EWMA_LAMBDA=0.94
MIN_TRADES_FOR_PROFILE=20
MIN_RESOLVED_FOR_ERROR_P2=100
MIN_RESOLVED_FOR_ERROR_P3=500

# === Confidence Engine ===
FOLLOW_MIN_TRADES=50
FOLLOW_MIN_FOLLOWERS=5
FADE_MIN_RESOLVED=50
FADE_MIN_CONFIDENCE=0.75
THOMPSON_EXPLORATION_FLOOR=0.10

# === Paper Trading + Risk ===
PAPER_TRADING=true
PAPER_CAPITAL_USDC=10000
MAX_POSITION_PCT=0.02
FADE_SIZE_RATIO=0.50
MAX_MARKET_EXPOSURE_PCT=0.25
MIN_POSITION_USDC=50

# === Live Trading (Polymarket CLOB) ===
# Master safety flag. While true, LiveTrader writes a live_trades row
# with status='shadow' and NEVER sends an order to the CLOB. Flip to
# false on the production VM ONLY after docs/live-trading-setup.md
# checklist is complete.
LIVE_TRADING_DRY_RUN=true
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
# Leave empty in dev. Populate ONLY on the VM, with a key that maps to
# the Polymarket Magic/proxy wallet that holds USDC. If empty, the
# wrapper forces dry-run regardless of LIVE_TRADING_DRY_RUN.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
# Limit-order placement: BUY @ mid+bps, SELL @ mid-bps. 50 bps = 0.5%.
LIVE_SLIPPAGE_BPS=50
# Cancel + reprice if not filled within this many seconds.
LIVE_ORDER_TIMEOUT_S=30
# Max cancel/reprice attempts per signal.
LIVE_ORDER_MAX_RETRIES=3
LIVE_FILL_POLL_INTERVAL_S=2.0

# === Decision Router (S2.7) ===
# Master mode at boot: paper / live / dual.
#   paper = decisions go to PaperTrader only (default, safe).
#   live  = decisions go to LiveTrader only (requires LIVE_TRADING_DRY_RUN
#           tuning and a working Polymarket wallet — see
#           docs/live-trading-setup.md).
#   dual  = paper sees ALL decisions, live sees only those passing the
#           LIVE_FILTER_* gates below. Use for shadow-comparison phase.
TRADING_MODE=paper
# Redis key for runtime override. SET this key to "paper"|"live"|"dual"
# to flip mode without restart (Telegram cmd / API endpoint will SET it).
TRADING_MODE_OVERRIDE_KEY=trading:mode_override
# Live-only filters (paper is unfiltered). Decisions below these
# thresholds are still recorded by paper but never reach live.
LIVE_FILTER_CONFIDENCE_MIN=0.6
LIVE_FILTER_SIZE_MIN_USDC=10.0
# Comma-separated market_id allowlist for live. Empty = no allowlist.
LIVE_MARKET_ALLOWLIST=

# === Batch Processing ===
BATCH_HOUR_UTC=3
BATCH_HAWKES_LEADERS=200
RETENTION_TRADES_DAYS=90

# === Scheduler + Watchdog (S3.10) ===
# Watchdog probes registered components every N seconds. Cheap (Redis
# read + task.done check), so 30s is plenty.
WATCHDOG_HEARTBEAT_INTERVAL_S=30
# Component is considered frozen if its heartbeat is older than this.
# Should exceed the busy-loop sleep of every monitored component.
WATCHDOG_HEARTBEAT_TIMEOUT_S=120
# Max consecutive restarts before we publish engine:crash and stop. The
# container should then restart at the Docker layer (S4.11).
WATCHDOG_MAX_RESTARTS=3
# Linear backoff between restarts: i × this many seconds.
WATCHDOG_RESTART_BACKOFF_S=10
# A component running uninterrupted for this long resets its restart
# counter — we don't punish a 4th flake on day 12.
WATCHDOG_RESTART_RESET_S=600
# Top-markets refresh cadence (seconds). 0 disables. Only run_all.py
# wires this — engine container has no observer.
REFRESH_MARKETS_INTERVAL_S=3600
# Killswitch DB→Redis sync cadence (seconds). 0 disables.
KILLSWITCH_SYNC_INTERVAL_S=300
# Daily Redis cleanup hour (UTC). Default 04:00 — one hour after the
# nightly batch.
REDIS_CLEANUP_HOUR_UTC=4

# === Backups → Cloudflare R2 (S4.12) ===
# Master switch. Default off so the container starts up cleanly in
# dev (no R2 creds). Flip true on the production VM after you've
# created the bucket + access key.
BACKUPS_ENABLED=false
# Cron hour (UTC). Default 05:00 — runs AFTER nightly_batch (03:00)
# and redis_cleanup (04:00) so the dump captures the post-batch state.
BACKUP_HOUR_UTC=5
# R2 endpoint has the form: https://<account_id>.r2.cloudflarestorage.com
# Find it in the Cloudflare dashboard → R2 → Overview → "S3 API".
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=polymarket-backups
# Object-key prefix inside the bucket. Allows one bucket to host
# multiple environments (postgres/, postgres-staging/, ...).
R2_KEY_PREFIX=postgres/
# GFS retention: 7 daily + 4 weekly (Sun) + 3 monthly (1st of month)
# = at most 14 objects retained, ~700 MB total for a 50 MB DB.
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3
# Day of week treated as the weekly anchor. 0=Mon, 6=Sun.
BACKUP_WEEKLY_DOW=6
# Hard ceiling on pg_dump runtime. A 50 MB DB dumps in <30s; 30 min
# protects against runaway processes (disk full, hung backend).
BACKUP_PG_DUMP_TIMEOUT_S=1800
# Where to write the dump on disk before streaming to R2. /tmp is
# tmpfs in most container runtimes — auto-cleaned on restart.
BACKUP_LOCAL_SCRATCH_DIR=/tmp

# === Telegram Bot (S3.9) ===
# Async-native ops bot. Pushes alerts (open/close, killswitch, crash) and
# accepts /status /pnl /positions /mode /killswitch /pause /resume.
# Disabled by default; set TELEGRAM_ENABLED=true + populate token + chat
# id allowlist to turn on. Empty allowlist auto-disables (defense in depth).
TELEGRAM_ENABLED=false
# Bot token from @BotFather. Treat as a secret — do NOT commit.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat_ids that may receive alerts AND issue commands.
# Get yours by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_IDS=
# Disable to receive push alerts only (no command surface) — useful when
# you don't want a 24/7 long-poll loop on a tiny VM.
TELEGRAM_COMMANDS_ENABLED=true
# Long-poll request timeout (seconds). 30s is the python-telegram-bot
# default and keeps idle connections cheap.
TELEGRAM_POLL_TIMEOUT_S=30
# Sliding-window cap on outbound notifications. Telegram's per-bot limit
# is ~30/sec; we stay far below to survive incident storms politely.
TELEGRAM_MAX_NOTIFICATIONS_PER_MINUTE=20

# === Logging ===
# Minimum loguru level. Valid: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL.
# Use INFO in prod, DEBUG locally. Invalid values fall back to INFO.
LOG_LEVEL=INFO
# Optional path to a rotating file sink. Empty = stderr only.
# On the Oracle Cloud VM set e.g. LOG_FILE=/var/log/polymarket-bot/app.log
LOG_FILE=
# Loguru rotation spec ("daily", "100 MB", "1 week", ...). See loguru docs.
LOG_FILE_ROTATION=daily
# How many rotated files to keep (older ones are zipped, then deleted).
LOG_FILE_RETENTION=14 days

# ------------------------------------------------------------------ #
# Retention sweep (Phase 0 Task D — audit R-6)                        #
# See docs/migrations/011_retention_policies.sql and the              #
# RETENTION_POLICIES table in scripts/batch_runner.py.                #
#                                                                     #
# Master switch. Default FALSE — the retention sweep is a no-op until #
# explicitly enabled. Run `python scripts/batch_runner.py --dry-run`  #
# first to preview impact before flipping this to true.               #
# ------------------------------------------------------------------ #
RETENTION_ENABLED=false

# Per-table overrides (days). Leave commented out to use the defaults #
# baked into RETENTION_POLICIES.                                      #
# RETENTION_DECISION_LOG_DAYS=90
# RETENTION_BOOK_QUALITY_SNAPSHOTS_DAYS=30
# RETENTION_PORTFOLIO_EQUITY_DAYS=180
# RETENTION_DECISION_STATE_TRANSITIONS_DAYS=90
# RETENTION_LIVE_ORDERS_DAYS=180
# RETENTION_SIGNAL_AUDITS_DAYS=90          # dormant table — index pre-emptive
# RETENTION_FEE_SNAPSHOTS_DAYS=90          # dormant table — index pre-emptive
# RETENTION_SYSTEM_CONTROL_AUDIT_DAYS=365
# RETENTION_RISK_CONFIG_HISTORY_DAYS=365

# =====================================================================
# Phase 1 — Data acquisition + observability (audit HP-1, HP-2)
# All values shown are defaults from src/config.py; uncomment to override.
# =====================================================================

# Trade observer REST poll cadence (was 30s; dropped to 5s for ~6x freshness gain).
# TRADE_OBSERVER_POLL_INTERVAL_S=5
# TRADE_OBSERVER_POLL_INTERVAL_S_MIN=1
# TRADE_OBSERVER_POLL_INTERVAL_S_MAX=60

# Trade observer bounded write queue (producer/consumer between _process_trade
# and _db_writer_loop). Backpressure: trades dropped when queue is full for >1s,
# counted in polybot_observer_queue_drops_total.
# TRADE_OBSERVER_QUEUE_MAX=10000
# TRADE_OBSERVER_BATCH_MAX=200
# TRADE_OBSERVER_BATCH_FLUSH_MS=100

# Falcon API concurrency. Semaphore raised from 1 to 8; the 60 RPM rate limiter
# remains the real ceiling. Backfill uses a separate gather() bound.
# FALCON_MAX_CONCURRENCY=8
# FALCON_MAX_REQUESTS_PER_MINUTE=60
# REGISTRY_BACKFILL_CONCURRENCY=20

# =====================================================================
# Phase 3 Task B — Smart Falcon Client
# Multi-key pool, adaptive token bucket, in-flight coalescing,
# conditional-GET revalidation. All-in-one rate-limit-respecting
# throughput maximisation. See docs/audit/phase3/B_smart_falcon.md.
# =====================================================================

# Multi-key rotation. Comma-separated list of Falcon API keys. The pool
# round-robins requests with a per-key token bucket. If empty, falls
# back to a 1-element list built from FALCON_API_KEY (backward-compat).
# Each key has its own 60 RPM bucket; total sustained throughput =
# N × FALCON_RPM_REFILL_PER_SEC × 60 calls/min. Within Falcon ToS:
# each key is independently rate-limited and we never exceed any one
# key documented cap.
# FALCON_API_KEYS=

# Adaptive token bucket. Bucket starts FULL (burst of CAPACITY calls go
# through immediately), then refills at REFILL_PER_SEC tokens/sec. On
# HTTP 429 the refill rate is halved for BACKOFF_S seconds, then
# restored. We DO NOT retry-on-429: we back off (slower), never faster.
# Default 60/1.0 matches Falcon documented 60 RPM contract; if you
# raise CAPACITY above 60 we log a WARNING (you should only do this if
# you have a private contract with Falcon).
# FALCON_RPM_BUCKET_CAPACITY=60
# FALCON_RPM_REFILL_PER_SEC=1.0
# FALCON_BACKOFF_S=60

# In-flight request coalescing. Two concurrent calls with the same
# (agent_id, params, limit, offset) share one HTTP request. After
# completion, the result is retained in process for this many seconds
# so a quick re-issue still returns the cached payload. INDEPENDENT
# of the 48h Redis cache — this is a short-window in-process dedup.
# FALCON_COALESCE_TTL_S=30

# Conditional-GET revalidation. After a cached payload is older than
# this many seconds (but within FALCON_CACHE_TTL_S), the next call
# revalidates with If-None-Match / If-Modified-Since. A 304 restores
# the cached payload without re-downloading. Only agents that return
# ETag / Last-Modified headers participate; others fall back to the
# full TTL cache (see phase3/B_smart_falcon.md for the matrix).
# FALCON_CONDITIONAL_REVALIDATE_S=3600


# =====================================================================
# Phase 2 — Schema evolution + PositionTracker persistence (audit M11..M15, R-4, F-04)
# =====================================================================

# Max open positions tracked in memory before LRU-by-open_time eviction.
# Eviction tracked in polybot_position_tracker_evictions_total.
# MAX_OPEN_POSITIONS_TRACKED=10000

# ============================================================================
# Round 6 (The Spine) — Data Sovereignty Layer
# See docs/ROUND_6_THE_SPINE.md for the full spec.
# ============================================================================

# --- src/rpc/ : Multi-provider Polygon RPC abstraction --------------------
# Ordered provider names, lowest priority first. Local Erigon is the
# preferred path (no rate limit, ~5 ms latency); the paid + free
# providers are fallbacks.
# RPC_PROVIDER_PRIORITIES=local_erigon,alchemy,quicknode

# Local Polygon node (Hetzner box-2). Reached over the private network.
# LOCAL_ERIGON_RPC_URL=http://10.0.0.2:8545
# LOCAL_ERIGON_WS_URL=ws://10.0.0.2:8546

# Paid fallback — populate with your Alchemy app's HTTPS endpoint + key.
# ALCHEMY_RPC_URL=
# ALCHEMY_RPC_API_KEY=

# Free fallback — populate with your QuickNode HTTPS endpoint + key.
# QUICKNODE_RPC_URL=
# QUICKNODE_RPC_API_KEY=

# Circuit breaker (per-provider): 5 consecutive failures → 60 s cooldown.
# RPC_CIRCUIT_BREAKER_THRESHOLD=5
# RPC_CIRCUIT_BREAKER_COOLDOWN_S=60
# RPC_HEALTHCHECK_INTERVAL_S=60

# --- src/onchain/ : Polymarket CLOB chain listener ------------------------
# Polymarket CTF Exchange contract on Polygon mainnet. Pinned in config —
# only override on a testnet deployment.
# POLYMARKET_CLOB_CONTRACT_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
# Alert when chain_blocks_behind exceeds this. 30 blocks ≈ 1 min lag.
# CHAIN_HEAD_LAG_ALERT_BLOCKS=30
# Listener boot: how far back to subscribe when chain_sync_state is empty.
# CHAIN_BOOTSTRAP_LOOKBACK_BLOCKS=256
# Cursor commit cadence (whichever comes first).
# CHAIN_BATCH_COMMIT_BLOCKS=50
# CHAIN_BATCH_COMMIT_INTERVAL_S=5

# --- src/crawler/ : Wallet Universe crawler ------------------------------
# Tier thresholds (USDC, 30-day rolling volume). See depth_tiers.py.
# WALLET_UNIVERSE_FULL_TIER_VOLUME_THRESHOLD_USDC=1000000
# WALLET_UNIVERSE_PERIODIC_TIER_VOLUME_THRESHOLD_USDC=50000
# How often the nightly tier-review sweep runs (seconds). 86400 = once daily.
# WALLET_UNIVERSE_REVIEW_INTERVAL_S=86400

# --- src/cold_storage/ : Parquet archival ---------------------------------
# Local root for the cold Parquet tree (Hetzner volume mount in prod).
# COLD_EXPORT_BASE_PATH=/data/cold
# Tables exported nightly. Comma-separated, no spaces.
# COLD_EXPORT_TABLES=trades_observed,book_quality_snapshots,orderbook_features_minute,decision_log,positions_reconstructed
# 0 = keep everything (default — cold storage is cheap).
# COLD_RETENTION_DAYS=0

# --- src/monitoring/coverage_reconciler.py -------------------------------
# Width of each reconciliation window (seconds). 300 = 5 min.
# COVERAGE_RECONCILER_WINDOW_S=300
# Minimum acceptable coverage_ratio{source} before the alert fires.
# COVERAGE_ALERT_THRESHOLD=0.95
